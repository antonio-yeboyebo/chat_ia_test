# Copia este fichero como .env y ajusta los valores

# URL base del servidor Python (sin trailing slash)
VITE_API_BASE_URL=http://localhost:8000

# Endpoint de la API de IA (ajusta según tu servidor)
VITE_API_ENDPOINT=/api/ia

# Endpoint SSE para streaming (propuesta de mejora Python)
# VITE_API_STREAM_ENDPOINT=/api/ia/stream
